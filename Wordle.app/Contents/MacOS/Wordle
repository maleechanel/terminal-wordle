#!/usr/bin/env python3
import http.server
import os
import socketserver
import subprocess
import sys
import threading
import tkinter as tk
import webbrowser

GAME_DIR = os.path.join(os.path.dirname(__file__), '..', 'Resources', 'game')
GAME_DIR = os.path.realpath(GAME_DIR)


def find_free_port():
    import socket
    with socket.socket() as s:
        s.bind(('', 0))
        return s.getsockname()[1]


def start_server(port):
    handler = http.server.SimpleHTTPRequestHandler
    handler.log_message = lambda *a: None  # suppress logs
    os.chdir(GAME_DIR)
    with socketserver.TCPServer(('127.0.0.1', port), handler) as httpd:
        httpd.serve_forever()


def open_in_app_window(url):
    # Try Chrome app mode first (no browser chrome, feels native)
    for chrome in [
        '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome',
        '/Applications/Chromium.app/Contents/MacOS/Chromium',
        '/Applications/Brave Browser.app/Contents/MacOS/Brave Browser',
    ]:
        if os.path.exists(chrome):
            subprocess.Popen([chrome, f'--app={url}', '--window-size=520,700'])
            return
    # Fall back to default browser
    webbrowser.open(url)


def main():
    port = find_free_port()
    url = f'http://127.0.0.1:{port}/index.html'

    t = threading.Thread(target=start_server, args=(port,), daemon=True)
    t.start()

    import time
    time.sleep(0.4)  # let server spin up

    open_in_app_window(url)

    # Small control window so the app stays alive and user can quit
    root = tk.Tk()
    root.title('Wordle')
    root.geometry('220x80')
    root.resizable(False, False)
    root.configure(bg='#ffffff')

    tk.Label(root, text='Wordle is running', font=('Helvetica', 13, 'bold'),
             bg='#ffffff', fg='#1a1a1b').pack(pady=(16, 6))
    tk.Button(root, text='Quit', command=root.destroy,
              bg='#6aaa64', fg='white', font=('Helvetica', 11, 'bold'),
              relief='flat', padx=16, pady=4, cursor='hand2').pack()

    root.mainloop()


if __name__ == '__main__':
    main()
