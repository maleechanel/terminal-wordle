# ─── Stats Persistence ────────────────────────────────────────────────────────

def load_stats() -> dict:
    """
    Load the player's persistent stats from disk.

    Reads from STREAK_FILE (.streak.json). If the file doesn't exist yet
    (i.e. the player's first session), returns a fresh stats dictionary
    with all counters set to zero.

    Returns:
        dict: A dictionary with keys:
            - "wins"   (int): Total games won across all sessions.
            - "losses" (int): Total games lost across all sessions.
            - "streak" (int): Current consecutive win streak.
            - "best"   (int): Best (longest) consecutive win streak ever.
    """
    if STREAK_FILE.exists():
        return json.loads(STREAK_FILE.read_text())
    return {"wins": 0, "losses": 0, "streak": 0, "best": 0}


def save_stats(stats: dict) -> None:
    """
    Save the player's current stats to disk.

    Writes the stats dictionary as JSON to STREAK_FILE so that
    win/loss/streak data persists between game sessions.

    Args:
        stats (dict): The stats dictionary to save (same shape as
                      the return value of load_stats).
    """
    STREAK_FILE.write_text(json.dumps(stats))


# ─── Game Logic ───────────────────────────────────────────────────────────────

def score_guess(guess: str, answer: str) -> list[str]:
    """
    Compare a player's guess against the secret answer and return tile colors.

    Uses a two-pass algorithm (the same logic used by the official NYT Wordle)
    to correctly handle duplicate letters:

    Pass 1 — Greens: Mark any letter that is in the exact correct position.
             Remove those letters from the remaining answer pool so they
             can't also be counted as yellows.

    Pass 2 — Yellows: For remaining (non-green) letters, check if the guessed
             letter exists anywhere in the leftover answer pool. If so, mark
             it yellow and consume that letter from the pool.

    This two-pass approach ensures that if the answer is "SPEED" and the
    player guesses "EERIE", only one E is marked yellow (not two), because
    only one unmatched E remains in the answer after the green pass.

    Args:
        guess  (str): The player's 5-letter guess (lowercase).
        answer (str): The secret 5-letter answer (lowercase).

    Returns:
        list[str]: A list of 5 color strings, one per letter.
                   Each value is "green", "yellow", or "gray".

    Example:
        >>> score_guess("crane", "brave")
        ['gray', 'green', 'yellow', 'gray', 'green']
    """
    tile_colors = ["gray"] * 5
    remaining_answer_letters = list(answer)

    # Pass 1: find exact matches (greens)
    for position, (guessed_letter, answer_letter) in enumerate(zip(guess, answer)):
        if guessed_letter == answer_letter:
            tile_colors[position] = "green"
            remaining_answer_letters[position] = None  # consume this letter

    # Pass 2: find misplaced matches (yellows)
    for position, guessed_letter in enumerate(guess):
        if tile_colors[position] == "green":
            continue  # already matched in pass 1
        if guessed_letter in remaining_answer_letters:
            tile_colors[position] = "yellow"
            remaining_answer_letters[remaining_answer_letters.index(guessed_letter)] = None

    return tile_colors


# ─── Rendering ────────────────────────────────────────────────────────────────

def render_tile(letter: str, color: str) -> str:
    """
    Wrap a single letter in its ANSI color codes to render a colored tile.

    Each tile is padded with one space on each side for readability.

    Args:
        letter (str): A single letter to display (will be uppercased).
        color  (str): One of "green", "yellow", or "gray".

    Returns:
        str: An ANSI-colored string ready to print to the terminal.

    Example:
        >>> render_tile("a", "green")
        '\033[42;30m A \033[0m'
    """
    color_to_ansi = {"green": GREEN, "yellow": YELLOW, "gray": GRAY}
    ansi_code = color_to_ansi.get(color, GRAY)
    return f"{ansi_code} {letter.upper()} {RESET}"


def render_board(
    guesses: list[tuple[str, list[str]]],
    max_guesses: int = MAX_GUESSES,
) -> str:
    """
    Render the full 6-row game board as a string of colored tiles.

    Completed rows show colored tiles for each guessed letter.
    Empty rows (not yet guessed) show blank gray placeholders.

    Args:
        guesses     (list): Each entry is a (guess_word, tile_colors) tuple,
                            where tile_colors is a list of 5 color strings.
        max_guesses (int):  Total number of rows to display (default 6).

    Returns:
        str: A multi-line string ready to print to the terminal.
    """
    rows = []

    # Render completed guess rows
    for guess_word, tile_colors in guesses:
        tiles = [render_tile(letter, color)
                 for letter, color in zip(guess_word, tile_colors)]
        rows.append(" ".join(tiles))

    # Render empty placeholder rows for remaining guesses
    empty_tile = f"{GRAY}   {RESET}"
    for _ in range(max_guesses - len(guesses)):
        rows.append(" ".join(empty_tile for _ in range(5)))

    return "\n".join(rows)


def render_keyboard(letter_states: dict[str, str]) -> str:
    """
    Render a color-coded on-screen keyboard showing used letter states.

    Letters are arranged in the standard QWERTY layout across three rows.
    Each letter is colored based on the best result seen so far:
        GREEN  — confirmed correct position in some past guess
        YELLOW — confirmed in word but wrong position
        GRAY   — confirmed not in the word
        (plain) — not yet guessed

    Args:
        letter_states (dict): Maps each used letter (str) to its best
                              color so far ("green", "yellow", or "gray").
                              Letters not in this dict haven't been guessed yet.

    Returns:
        str: A multi-line ANSI-colored keyboard string.
    """
    keyboard_rows = ["qwertyuiop", "asdfghjkl", "zxcvbnm"]
    rendered_rows = []

    for row in keyboard_rows:
        tiles = []
        for letter in row:
            state = letter_states.get(letter, "none")
            if state == "green":
                tiles.append(f"{GREEN} {letter.upper()} {RESET}")
            elif state == "yellow":
                tiles.append(f"{YELLOW} {letter.upper()} {RESET}")
            elif state == "gray":
                tiles.append(f"{GRAY} {letter.upper()} {RESET}")
            else:
                tiles.append(f" {letter.upper()} ")  # unguessed — no color
        rendered_rows.append(" ".join(tiles))

    return "\n".join(rendered_rows)


def redraw_screen(
    guesses: list[tuple[str, list[str]]],
    letter_states: dict[str, str],
    message: str = "",
    stats: dict = None,
) -> None:
    """
    Clear the terminal and redraw the complete game UI.

    Prints, in order:
        1. The title banner
        2. The 6-row game board
        3. The color-coded QWERTY keyboard
        4. The player's current stats (wins, losses, streak, best)
        5. An optional status message (e.g. error or win message)

    This function is called after every guess to refresh the display,
    giving the game a clean, flicker-free appearance.

    Args:
        guesses       (list): Completed guesses so far (word + tile colors).
        letter_states (dict): Current color state of each used letter.
        message       (str):  Optional status message to show at the bottom.
        stats         (dict): Player stats dict from load_stats(). If None,
                              the stats line is omitted.
    """
    print(CLEAR, end="")
    print(f"{BOLD}  W O R D L E{RESET}  —  Guess the 5-letter word in 6 tries\n")
    print(render_board(guesses))
    print()
    print(render_keyboard(letter_states))
    print()
    if stats:
        print(
            f"  Wins: {stats['wins']}  "
            f"Losses: {stats['losses']}  "
            f"Streak: {stats['streak']}  "
            f"Best: {stats['best']}"
        )
    if message:
        print(f"\n  {message}")


# ─── Main Game Loop ───────────────────────────────────────────────────────────

def play() -> None:
    """
    Run one complete game of Wordle and prompt to play again.

    Game flow:
        1. Pick a random secret answer from WORD_LIST.
        2. Load the player's persistent stats.
        3. Loop up to MAX_GUESSES times:
            a. Prompt the player for a 5-letter alphabetic guess.
            b. Score the guess using score_guess().
            c. Update the on-screen keyboard state (keep best color per letter).
            d. Redraw the screen with the new board and keyboard.
            e. If the guess matches the answer, record a win and break.
        4. If all guesses are used without winning, record a loss.
        5. Save updated stats and offer to play again (calls play() recursively).

    Handles Ctrl+C and EOF gracefully by revealing the answer and exiting.
    """
    secret_answer = random.choice(WORD_LIST)
    completed_guesses: list[tuple[str, list[str]]] = []
    letter_states: dict[str, str] = {}  # tracks best color seen per letter
    stats = load_stats()
    player_won = False

    # Victory messages indexed by attempt number (1-6).
    # Earlier wins get more effusive praise.
    victory_messages = [
        "Genius!",        # solved in 1
        "Magnificent!",   # solved in 2
        "Impressive!",    # solved in 3
        "Splendid!",      # solved in 4
        "Great!",         # solved in 5
        "Phew!",          # solved in 6
    ]

    redraw_screen(completed_guesses, letter_states, stats=stats)

    for attempt_number in range(1, MAX_GUESSES + 1):

        # ── Input loop: keep asking until we get a valid 5-letter word ──
        while True:
            try:
                raw_input = input(f"  Guess {attempt_number}/{MAX_GUESSES}: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print(f"\n  The word was: {BOLD}{secret_answer.upper()}{RESET}")
                sys.exit(0)

            if len(raw_input) != 5:
                redraw_screen(completed_guesses, letter_states,
                              "Enter a 5-letter word.", stats)
                continue
            if not raw_input.isalpha():
                redraw_screen(completed_guesses, letter_states,
                              "Letters only, please.", stats)
                continue
            break  # valid guess — exit input loop

        # ── Score the guess and update game state ──
        tile_colors = score_guess(raw_input, secret_answer)
        completed_guesses.append((raw_input, tile_colors))

        # Update letter_states: keep the highest-priority color seen per letter
        for letter, color in zip(raw_input, tile_colors):
            current_priority = COLOR_PRIORITY.get(letter_states.get(letter, "none"), 0)
            new_priority = COLOR_PRIORITY[color]
            if new_priority > current_priority:
                letter_states[letter] = color

        # ── Check for win ──
        if raw_input == secret_answer:
            player_won = True
            stats["wins"]   += 1
            stats["streak"] += 1
            stats["best"]    = max(stats["best"], stats["streak"])
            save_stats(stats)

            redraw_screen(completed_guesses, letter_states, stats=stats)
            praise = victory_messages[attempt_number - 1]
            print(f"\n  {BOLD}{praise}{RESET}  Solved in {attempt_number}/{MAX_GUESSES}\n")
            break

        redraw_screen(completed_guesses, letter_states, stats=stats)

    # ── Handle loss ──
    if not player_won:
        stats["losses"] += 1
        stats["streak"]  = 0
        save_stats(stats)
        redraw_screen(completed_guesses, letter_states, stats=stats)
        print(f"\n  Better luck next time! "
              f"The word was: {BOLD}{secret_answer.upper()}{RESET}\n")

    # ── Offer to play again ──
    try:
        play_again = input("  Play again? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        play_again = "n"

    if play_again == "y":
        play()


# ─── Entry Point ──────────────────────────────────────────────────────────────

if __name__ == "__main__":
    play()
