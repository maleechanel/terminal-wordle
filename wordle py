#!/usr/bin/env python3
"""
terminal-wordle
===============
A faithful clone of the NYT Wordle game that runs entirely in your terminal.

Rules:
    - Guess a secret 5-letter word in 6 attempts.
    - After each guess, tiles are colored to show how close you were:
        GREEN  — correct letter, correct position
        YELLOW — correct letter, wrong position
        GRAY   — letter not in the word at all

Usage:
    python3 wordle.py

Persistent stats (wins, losses, streak, best streak) are saved locally
in a hidden file called .streak.json next to this script.

Author: Sumalee Simmonds
GitHub: https://github.com/maleechanel/terminal-wordle
"""

import json
import os
import random
import sys
from pathlib import Path


# ─── Terminal Color Codes (ANSI escape sequences) ─────────────────────────────
# These tell the terminal to change background/foreground colors.
# Format: \033[<background>;<foreground>m
# GREEN  = green background, black text  (correct letter, correct position)
# YELLOW = yellow background, black text (correct letter, wrong position)
# GRAY   = dark gray background, white text (letter not in word)
# BOLD   = bold text
# RESET  = return terminal to its default colors
# CLEAR  = clear the entire terminal screen and move cursor to top-left

GREEN  = "\033[42;30m"
YELLOW = "\033[43;30m"
GRAY   = "\033[100;37m"
BOLD   = "\033[1m"
RESET  = "\033[0m"
CLEAR  = "\033[2J\033[H"

# How each color name maps to a display priority.
# When a letter appears multiple times in guesses with different colors,
# we keep the highest-priority color (green beats yellow beats gray).
COLOR_PRIORITY: dict[str, int] = {
    "green":  3,
    "yellow": 2,
    "gray":   1,
    "none":   0,
}

# Maximum number of guesses allowed per game (standard Wordle rule).
MAX_GUESSES = 6

# File path where win/loss/streak stats are saved between sessions.
STREAK_FILE = Path(__file__).parent / ".streak.json"


